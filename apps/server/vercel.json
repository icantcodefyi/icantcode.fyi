{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && bun install",
  "buildCommand": "cd ../.. && turbo run build --filter=server",
  "redirects": [{ "source": "/", "destination": "/healthz", "permanent": false }],
  "rewrites": [{ "source": "/(.*)", "destination": "/api/hono" }]
}
